<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Exportar Blitz Veicular</title>

    <script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2"></script>
    <script src="https://cdn.jsdelivr.net/npm/xlsx/dist/xlsx.full.min.js"></script>
</head>

<body>

<button id="btnExportar">
    Gerar Excel
</button>

<div id="status"></div>

<script>

const supabaseClient = supabase.createClient(
    "https://dptxznkhhhuezhjixtvf.supabase.co",
    "sb_publishable_mMejXWvyWg8n2V9_nMBJNQ_-E2e1rJP"
);

document.getElementById("btnExportar")
.addEventListener("click", exportarExcel);

async function exportarExcel(){

    const status = document.getElementById("status");

    status.innerHTML = "Consultando dados...";

    const { data, error } = await supabaseClient
        .from("blitz_veicular")
        .select("*");

    if(error){
        console.log(error);
        status.innerHTML = error.message;
        return;
    }

    const ws = XLSX.utils.json_to_sheet(data);

    const wb = XLSX.utils.book_new();

    XLSX.utils.book_append_sheet(
        wb,
        ws,
        "Blitz"
    );

    XLSX.writeFile(
        wb,
        "blitz_veicular.xlsx"
    );

    status.innerHTML = "Arquivo gerado com sucesso";
}

</script>

</body>
</html>
